# WebSocket feed URL
WEBSOCKET_URL=https://terminal.finosauras.com
SOCKET_TOKEN=your_jwt_token_here

# Meta / Instagram Graph API
INSTAGRAM_ACCOUNT_ID=your_instagram_business_account_id
META_ACCESS_TOKEN=your_long_lived_access_token
META_API_VERSION=v19.0

# Image hosting — images must be publicly accessible for Meta API to fetch them.
IMAGE_HOST_TYPE=local          # "local" | "s3" | "custom_url"
IMAGE_SERVER_PORT=3500
IMAGE_SERVER_PUBLIC_URL=http://<EC2-PUBLIC-IP>:3500   # Meta API fetches images from here

# If IMAGE_HOST_TYPE=s3
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=

# Branding
WATERMARK_TEXT=@YourHandle • StockAlerts

# Logging
LOG_LEVEL=info    # error | warn | info | debug

# Dashboard port (used by worker's built-in dashboard)
PORT=3501
